<Window x:Class="RageOptimization.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RAGE OPTIMIZATION" 
        Height="680" Width="1050"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="{StaticResource BorderBrush}">

    <Window.Resources>
        <!-- Custom ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Name="ListItemBorder" Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="#1C1C22"/>
                                <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="#442222"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="#2A1616"/>
                                <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="#FF1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Glass Card Style -->
        <Style x:Key="PremiumCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#151518" Offset="0.0"/>
                        <GradientStop Color="#0D0D0F" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#252528"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="4" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glowing Neon ProgressBar Style -->
        <Style x:Key="GlowProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#0A0A0C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2.5"/>
                            <Border Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1A1A" Offset="0.0"/>
                                        <GradientStop Color="#FF5555" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="240"/>
            <!-- Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Logo / Brand -->
                    <RowDefinition Height="80"/>
                    <!-- Menu Buttons -->
                    <RowDefinition Height="*"/>
                    <!-- User Info Section -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand Logo Header -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="RAGE" Foreground="#FF1A1A" FontSize="26" FontWeight="Black">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF1A1A" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="OPTIMIZATION" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" Margin="0,-3,0,0"/>
                </StackPanel>

                <!-- Sidebar Buttons -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource CustomScrollViewer}">
                    <StackPanel x:Name="SidebarContainer" Margin="0,10,0,0">
                        <Button Content="📊  Dashboard" Style="{StaticResource SidebarButton}" Tag="Active" Click="SidebarBtn_Click" Name="BtnDashboard"/>
                        <Button Content="🔥  Free Fire Tweaks" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnFreeFire"/>
                        <Button Content="🚀  FPS Boost" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnFps"/>
                        <Button Content="⚡  Network &amp; Latency" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnNetwork"/>
                        <Button Content="🧹  Cleaner Tools" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnCleaner"/>
                        <Button Content="🔋  Power Optimization" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnPower"/>
                        <Button Content="⚙️  Advanced Tweaks" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnAdvanced"/>
                        <Button Content="🔑  License Manager" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnLicense"/>
                        <Button Content="🛡️  Admin Settings" Style="{StaticResource SidebarButton}" Click="SidebarBtn_Click" Name="BtnAdmin" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- User Footer Panel -->
                <Border Grid.Row="2" Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="FooterUserText" Text="User: Clasher" Foreground="#FFFFFF" FontWeight="Bold" FontSize="11"/>
                        <TextBlock x:Name="FooterLicenseText" Text="Type: Premium Key" Foreground="#9A9A9E" FontSize="9" Margin="0,2,0,0"/>
                        <TextBlock x:Name="FooterHwidText" Text="HWID: Computing..." Foreground="#FF3333" FontSize="8" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Side Panel Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Titlebar Header -->
                <RowDefinition Height="50"/>
                <!-- Selected Panel Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Top Header Bar (Draggable) -->
            <Border Grid.Row="0" Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseDown="TitleBar_MouseDown">
                <Grid Margin="20,0,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <Ellipse Width="8" Height="8" Fill="#44BB44" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#44BB44" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="SYSTEM SECURED &amp; RUNNING IN GAMER MODE" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="-" Foreground="#9A9A9E" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Hand" Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#222"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✕" Foreground="#9A9A9E" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Hand" Click="CloseButton_Click" Margin="5,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF1A1A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Active Content Container Panels -->
            <Grid Grid.Row="1" Margin="25">
                
                <!-- 1. DASHBOARD PANEL -->
                <Grid x:Name="PanelDashboard" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <!-- Metrics Cards -->
                        <RowDefinition Height="140"/>
                        <!-- Boost Buttons Area -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Realtime Hardware Stats cards -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: CPU -->
                        <Border Grid.Column="0" Style="{StaticResource PremiumCard}" Margin="0,0,10,0" Padding="15">
                            <Grid>
                                <TextBlock Text="CPU LOAD" Foreground="#9A9A9E" FontSize="9" FontWeight="Bold" VerticalAlignment="Top"/>
                                <TextBlock Text="💻" FontSize="14" Foreground="#FF1A1A" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <TextBlock x:Name="TxtCpuVal" Text="14%" Foreground="#FFFFFF" FontSize="26" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                                <ProgressBar x:Name="ProgCpu" Value="14" Maximum="100" Style="{StaticResource GlowProgressBar}" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Card 2: GPU -->
                        <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="5,0,5,0" Padding="15">
                            <Grid>
                                <TextBlock Text="GPU LOAD" Foreground="#9A9A9E" FontSize="9" FontWeight="Bold" VerticalAlignment="Top"/>
                                <TextBlock Text="🎮" FontSize="14" Foreground="#FF1A1A" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <TextBlock x:Name="TxtGpuVal" Text="8%" Foreground="#FFFFFF" FontSize="26" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                                <ProgressBar x:Name="ProgGpu" Value="8" Maximum="100" Style="{StaticResource GlowProgressBar}" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Card 3: RAM -->
                        <Border Grid.Column="2" Style="{StaticResource PremiumCard}" Margin="5,0,5,0" Padding="15">
                            <Grid>
                                <TextBlock Text="RAM UTILITY" Foreground="#9A9A9E" FontSize="9" FontWeight="Bold" VerticalAlignment="Top"/>
                                <TextBlock Text="🧠" FontSize="14" Foreground="#FF1A1A" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <TextBlock x:Name="TxtRamVal" Text="42%" Foreground="#FFFFFF" FontSize="26" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                                <ProgressBar x:Name="ProgRam" Value="42" Maximum="100" Style="{StaticResource GlowProgressBar}" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Card 4: Ping Checker -->
                        <Border Grid.Column="3" Style="{StaticResource PremiumCard}" Margin="10,0,0,0" Padding="15">
                            <Grid>
                                <TextBlock Text="LATENCY PING" Foreground="#9A9A9E" FontSize="9" FontWeight="Bold" VerticalAlignment="Top"/>
                                <TextBlock Text="📶" FontSize="14" Foreground="#44BB44" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <TextBlock x:Name="TxtPingVal" Text="28 ms" Foreground="#44BB44" FontSize="26" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                                <TextBlock x:Name="TxtWinVer" Text="Windows 11 x64" Foreground="#9A9A9E" FontSize="9" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Central Gaming Booster Button & Event log -->
                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Action Area -->
                        <Border Grid.Column="0" Style="{StaticResource PremiumCard}" Padding="25" Margin="0,0,10,0">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="SYSTEM SPEED REACTOR" Foreground="#FF3333" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <Button x:Name="BtnBoostNow" Content="ACTIVATE SYSTEM BOOST" Width="240" Height="54" Style="{StaticResource RgbButton}" FontSize="15" FontWeight="ExtraBold" Click="BtnBoostNow_Click">
                                        <Button.Effect>
                                            <DropShadowEffect Color="#FF1A1A" BlurRadius="25" ShadowDepth="0" Opacity="0.95"/>
                                        </Button.Effect>
                                    </Button>
                                    <TextBlock Text="Trigger general performance cleanup, optimize registry latency parameters, activate GPU and power priorities instantly." Foreground="#9A9A9E" FontSize="11" TextAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Log / Console Output -->
                        <Border Grid.Column="1" Background="#060608" BorderBrush="#252528" BorderThickness="1" CornerRadius="6" Padding="15" Margin="10,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="OPTIMIZER ACTIVITY LOG" Foreground="#FF1A1A" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBox Grid.Row="1" x:Name="DashboardConsole" Background="Transparent" BorderThickness="0" Foreground="#00FF66" FontFamily="Consolas" FontSize="11" VerticalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="Wrap" VerticalAlignment="Stretch" Text="Ready to boost gaming parameters...&#x0a;HWID checked successfully.&#x0a;" Opacity="0.85"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 2. FREE FIRE OPTIMIZATION PANEL -->
                <Grid x:Name="PanelFreeFire" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource CustomScrollViewer}">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="FREE FIRE LATENCY &amp; EMULATOR BOOST" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                            <TextBlock Text="Reduce mouse polling delays, prioritize BlueStacks/LDPlayer, and activate competitive touch metrics." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ultra Sensitivity &amp; Input Delay Reduction" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="Modifies mouse speed parameters, accessibility delay triggers, and registry device queues." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock Text="Risk Level: Safe" Foreground="#44BB44" FontSize="10" FontWeight="Bold" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="APPLY TWEAK" Style="{StaticResource RgbButton}" Width="120" Height="35" Click="ApplyFreeFireTweak_Click" Tag="InputDelay"/>
                                </Grid>
                            </Border>

                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Emulator Engine Hardware Acceleration" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="Boosts CPU thread priority allocation specifically for BlueStacks, GameLoop, and LDPlayer." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock Text="Risk Level: Safe" Foreground="#44BB44" FontSize="10" FontWeight="Bold" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="APPLY TWEAK" Style="{StaticResource RgbButton}" Width="120" Height="35" Click="ApplyFreeFireTweak_Click" Tag="EmulatorOptimize"/>
                                </Grid>
                            </Border>

                            <!-- Custom Hacker Sensi Tweaks Section -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Left: Headshot Sensi -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="🎯 EMULATOR SENSITIVITY TWEAKS" Foreground="#FF1A1A" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="5">
                                        <ListBox x:Name="ListFreeFireCustom" Height="220" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding TweakType}" Foreground="#9A9A9E" FontSize="9"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="RUN" Width="50" Height="22" Click="RunCustomTweak_Click" Style="{StaticResource RgbButton}" FontSize="9"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>

                                <!-- Right: Mouse Regedits -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="🖱️ MOUSE &amp; NO RECOIL REGEDITS" Foreground="#FF1A1A" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="5">
                                        <ListBox x:Name="ListMouseCustom" Height="220" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding TweakType}" Foreground="#9A9A9E" FontSize="9"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="RUN" Width="50" Height="22" Click="RunCustomTweak_Click" Style="{StaticResource RgbButton}" FontSize="9"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- 3. FPS BOOST PANEL -->
                <Grid x:Name="PanelFps" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource CustomScrollViewer}">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="FPS BOOST ENGINE" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                            <TextBlock Text="Switch between priority profiles to maximize frame throughput in high-action games." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,10,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="LOW-END PC" Foreground="#9A9A9E" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Maximize frames by turning off system graphics and widgets." Foreground="#FFFFFF" FontSize="10" Margin="0,10" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <Button Content="ACTIVATE" Style="{StaticResource RgbButton}" Height="30" Width="100" Click="ActivateProfile_Click" Tag="LowEnd"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="5,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="HIGH-END PC" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Balance high quality textures with processor scheduling overrides." Foreground="#FFFFFF" FontSize="10" Margin="0,10" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <Button Content="ACTIVATE" Style="{StaticResource RgbButton}" Height="30" Width="100" Click="ActivateProfile_Click" Tag="HighEnd"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="10,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="ESPORTS PRO" Foreground="#FF1A1A" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#FF1A1A" BlurRadius="6" ShadowDepth="0"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="Zero out input lag. Full CPU/GPU prioritization for esports games." Foreground="#FFFFFF" FontSize="10" Margin="0,10" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <Button Content="ACTIVATE" Style="{StaticResource RgbButton}" Height="30" Width="100" Click="ActivateProfile_Click" Tag="Esports"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="GPU Priority Scheduling &amp; Task Tweaks" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Configures Windows Multimedia Task Scheduler to map 100% of thread pools to primary GPU workloads." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,15"/>
                                    <Button Content="APPLY GPU PRIORITY REGISTRY TWEAK" Style="{StaticResource RgbButton}" Height="38" Click="ApplyFpsRegistryTweak_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Custom FPS Boost Tweaks -->
                            <TextBlock Text="🚀 CUSTOM FPS OPTIMIZATIONS" Foreground="#FF1A1A" FontSize="11" FontWeight="Bold" Margin="0,10,0,8"/>
                            <Border Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="5">
                                <ListBox x:Name="ListFpsCustom" Height="180" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#FFFFFF" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding TweakFile}" Foreground="#9A9A9E" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="APPLY" Width="60" Height="24" Click="RunCustomTweak_Click" Style="{StaticResource RgbButton}" FontSize="9"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- 4. NETWORK & LATENCY PANEL -->
                <Grid x:Name="PanelNetwork" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="NETWORK &amp; LATENCY TUNING" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Optimize TCP parameters and replace DNS servers with low-latency equivalents." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Select Fast Gaming DNS Server" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Cloudflare (1.1.1.1)" Style="{StaticResource RgbButton}" Margin="0,0,8,0" Click="ChangeDns_Click" Tag="1.1.1.1"/>
                                    <Button Grid.Column="1" Content="Google (8.8.8.8)" Style="{StaticResource RgbButton}" Margin="4,0,4,0" Click="ChangeDns_Click" Tag="8.8.8.8"/>
                                    <Button Grid.Column="2" Content="Restore Default DNS" Style="{StaticResource RgbButton}" Margin="8,0,0,0" Click="ChangeDns_Click" Tag="DHCP"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Optimize TCP Settings &amp; Disable Nagle's Algorithm" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Forces instant packet ACK transmissions (TCPAckFrequency = 1) to drastically reduce ping." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="ACTIVATE TCP TWEAKS" Style="{StaticResource RgbButton}" Width="150" Height="35" Click="ApplyTcpTweak_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 5. CLEANER PANEL -->
                <Grid x:Name="PanelCleaner" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="CLEANER TOOLS" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Scan and eliminate background junk files, shader cache files, and system prefetch logs." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="25" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtJunkScanStatus" Text="Ready to analyze system cache..." Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtJunkSize" Text="Estimated space to free: 1.24 GB" Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="RUN SYSTEM CLEANUP" Style="{StaticResource RgbButton}" Width="180" Height="45" Click="RunCleanup_Click"/>
                            </Grid>
                        </Border>

                        <Border Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15">
                            <StackPanel>
                                <TextBlock Text="CLEANER SETTINGS" Foreground="#FF1A1A" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <CheckBox Content="Clear Windows Prefetch Logs" Foreground="#FFFFFF" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox Content="Clear DirectX &amp; Shader Caches" Foreground="#FFFFFF" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox Content="Clear User &amp; System Temp Files" Foreground="#FFFFFF" IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox Content="Clear Emulator Cache Files (BlueStacks/LDPlayer)" Foreground="#FFFFFF" IsChecked="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 6. POWER OPTIMIZATION PANEL -->
                <Grid x:Name="PanelPower" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="POWER OPTIMIZATION" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Unlock ultimate processor frequencies by disabling power index throttling." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CPU Core Unparking (Ultimate System Control)" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Forces Windows scheduler to keep all processor threads continuously active during gameplay." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="UNPARK CORES" Style="{StaticResource RgbButton}" Width="130" Height="35" Click="UnparkCores_Click"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Activate Ultimate Performance Power Plan" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Forces Windows core scheduler to use zero-latency power plan parameters." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="ACTIVATE POWER SCHEME" Style="{StaticResource RgbButton}" Width="160" Height="35" Click="ActivatePowerScheme_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 7. ADVANCED TWEAKS PANEL -->
                <Grid x:Name="PanelAdvanced" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="ADVANCED WINDOWS TWEAKS" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Apply deep-level adjustments. We highly recommend creating a System Restore Point before continuing." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Disable System Telemetry &amp; Background Reporting" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Shuts down Windows DiagTrack and feedback service telemetry to save CPU resources." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="APPLY TELEMETRY TWEAK" Style="{StaticResource RgbButton}" Width="170" Height="35" Click="ApplyTelemetryTweak_Click"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Create Windows System Restore Point" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Generates an immediate system checkpoint to easily rollback tweaks in case of conflicts." Foreground="#9A9A9E" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="CREATE RESTORE POINT" Style="{StaticResource RgbButton}" Width="160" Height="35" Click="CreateRestorePoint_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 8. LICENSE MANAGER PANEL -->
                <Grid x:Name="PanelLicense" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="LICENSE MANAGER" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Check active subscription dates, account state, and secure hardware linkage details." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="Logged Username:" Foreground="#9A9A9E" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock x:Name="LicenseUser" Text="Clasher" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="Key Expiry Date:" Foreground="#9A9A9E" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock x:Name="LicenseExpiry" Text="Never (Demo Mode)" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,12">
                                    <TextBlock Text="License Key:" Foreground="#9A9A9E" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock x:Name="LicenseKeyText" Text="RAGE-DEMO-EXPRESS" Foreground="#FF3333" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <TextBlock Text="Hardware Fingerprint (HWID):" Foreground="#9A9A9E" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock x:Name="LicenseHwidText" Text="Unknown" Foreground="#FFFFFF" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 9. ADMIN PANEL -->
                <Grid x:Name="PanelAdmin" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="ADMIN LICENSE CREATOR" Foreground="#FFFFFF" FontSize="20" FontWeight="ExtraBold"/>
                        <TextBlock Text="Generate new license keys and reset HWID locks in the Firebase/Firestore database records." Foreground="#9A9A9E" FontSize="12" Margin="0,5,0,25"/>

                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                            <StackPanel>
                                <TextBlock Text="GENERATE NEW LICENSE KEY" Foreground="#FF1A1A" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>

                                <TextBlock Text="LICENSE KEY STRING" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="AdminNewKeyInput" Text="RAGE-NEW-KEY-100" Margin="0,0,0,12"/>

                                <TextBlock Text="BIND USERNAME" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="AdminNewUserInput" Text="Gamer" Margin="0,0,0,12"/>

                                <TextBlock Text="DAYS ACTIVE" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="AdminDaysInput" Text="30" Margin="0,0,0,20"/>

                                <Button Content="CREATE LICENSE RECORD IN DATABASE" Style="{StaticResource RgbButton}" Height="38" Click="AdminCreateKey_Click" Margin="0,0,0,15"/>
                                <Button Content="RESET HWID LOCK FOR KEY" Style="{StaticResource RgbButton}" Height="38" Click="AdminResetHwid_Click"/>
                                
                                <TextBlock x:Name="AdminStatusText" Text="" Foreground="#44FF44" FontSize="11" FontWeight="Bold" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
