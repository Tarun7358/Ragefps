<Window x:Class="RageOptimization.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rage Optimization - Authentication" 
        Height="540" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="{StaticResource BorderBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Titlebar -->
            <RowDefinition Height="35"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title bar -->
        <Border Grid.Row="0" Background="#0C0C0E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseDown="TitleBar_MouseDown">
            <Grid Margin="15,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="RAGE" Foreground="#FF1A1A" FontWeight="ExtraBold" VerticalAlignment="Center" FontSize="12"/>
                    <TextBlock Text=" OPTIMIZATION AUTH" Foreground="#9A9A9E" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="-" Foreground="#9A9A9E" Background="Transparent" BorderThickness="0" Width="25" Height="25" Cursor="Hand" Click="MinimizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#222"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Foreground="#9A9A9E" Background="Transparent" BorderThickness="0" Width="25" Height="25" Cursor="Hand" Click="CloseButton_Click" Margin="5,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF1A1A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Auth View -->
        <Grid Grid.Row="1" Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <!-- Logo Header -->
                <RowDefinition Height="Auto"/>
                <!-- Form Inputs -->
                <RowDefinition Height="*"/>
                <!-- Status Message -->
                <RowDefinition Height="Auto"/>
                <!-- HWID Status -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Brand Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,5,0,15">
                <TextBlock Text="RAGE" Foreground="#FF1A1A" FontSize="36" FontWeight="Black" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF1A1A" BlurRadius="25" ShadowDepth="0" Opacity="0.9"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="PC OPTIMIZATION SUITE" Foreground="#9A9A9E" FontSize="11" FontWeight="Bold" Margin="0,-5,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="USERNAME" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameInput" Text="Clasher" Margin="0,0,0,15"/>

                <TextBlock Text="PASSWORD" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordInput" Margin="0,0,0,15"/>

                <TextBlock Text="LICENSE KEY" Foreground="#9A9A9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LicenseInput" Text="RAGE-DEMO-EXPRESS" Margin="0,0,0,20"/>

                <Button x:Name="LoginBtn" Content="LOGIN &amp; BOOST" Style="{StaticResource RgbButton}" Height="42" Click="LoginBtn_Click"/>
            </StackPanel>

            <!-- Status message Row -->
            <TextBlock Grid.Row="2" x:Name="StatusMessage" Text="" Foreground="#FF3333" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,15" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>

            <!-- HWID & Footer -->
            <StackPanel Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,5">
                <Border Background="#121214" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6" MouseLeftButtonDown="HwidBorder_Click" Cursor="Hand" ToolTip="Click to Copy HWID">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="HWID: " Foreground="#FF1A1A" FontWeight="Bold" FontSize="10"/>
                        <TextBlock Grid.Column="1" x:Name="HwidText" Text="Computing fingerprint..." Foreground="#9A9A9E" FontSize="10" TextTrimming="CharacterEllipsis" Margin="5,0,0,0"/>
                    </Grid>
                </Border>
                <TextBlock Text="🔒 Secure HWID Connection Active" Foreground="#44BB44" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
